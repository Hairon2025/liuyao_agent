# 应用配置
APP_NAME=liuyao-agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# SQLite 默认路径；部署时可替换成其他 SQLAlchemy 异步数据库 URL
DATABASE_URL=sqlite+aiosqlite:///./backend/running_data/liuyao.db

# LLM 配置
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# CORS
CORS_ORIGINS=["*"]
